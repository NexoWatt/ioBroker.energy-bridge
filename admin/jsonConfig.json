{
  "i18n": true,
  "type": "tabs",
  "items": {
    "general": {
      "type": "panel",
      "label": "General",
      "items": {
        "_alive": {
          "type": "alive",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "textAlive": "Instance is running",
          "textNotAlive": "Instance is not running"
        },
        "connection": {
          "type": "state",
          "label": "Connection",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6,
          "oid": "info.connection",
          "control": "switch",
          "readOnly": true
        },
        "pollIntervalMs": {
          "type": "number",
          "label": "Poll interval (ms)",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6,
          "min": 1000,
          "max": 600000,
          "step": 100
        },
        "modbusTimeoutMs": {
          "type": "number",
          "label": "Modbus timeout (ms)",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6,
          "min": 200,
          "max": 60000,
          "step": 100
        },
        "registerAddressOffset": {
          "type": "number",
          "label": "Register address offset",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6,
          "min": -10000,
          "max": 10000,
          "step": 1
        },
        "_note": {
          "type": "staticText",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "newLine": true,
          "text": "Device definitions are configured in the Devices tab."
        }
      }
    },
    "devices": {
      "type": "panel",
      "label": "Devices",
      "items": {
        "devicesJson": {
          "type": "jsonEditor",
          "label": "Devices configuration (JSON)",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "validateJson": true,
          "allowEmpty": true
        },
        "_devicesHelp": {
          "type": "staticText",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "newLine": true,
          "text": "The value must be a JSON array (e.g. []). Add your device definitions in the editor."
        }
      }
    }
  }
}